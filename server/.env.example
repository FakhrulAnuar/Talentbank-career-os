# Copy to .env — loaded via: node --env-file=.env src/index.js
# In production these are validated at boot; a missing SESSION_SECRET will refuse to start.
PORT=4000
DB_FILE=./ascend.db
NODE_ENV=development
# Generate a real one, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
