# Copy to .env — loaded via: node --env-file=.env src/index.js
# In production these are validated at boot; a missing SESSION_SECRET will refuse to start.
PORT=4000
DB_FILE=./ascend.db
NODE_ENV=development
# Generate a real one, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# --- Optional: real-catalog ingestion (Roadmap step 2). Features stay off until set. ---
# YouTube Data API v3 key (free, 10k units/day): https://console.cloud.google.com/apis
YOUTUBE_API_KEY= 
# Adzuna jobs API (free tier): https://developer.adzuna.com/  (country: gb, us, sg, ...)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=   # one or more, comma-separated e.g. sg,gb,us
# Auto-run ingestion every N minutes (0 = off; trigger manually via POST /api/ingest/run)
INGEST_INTERVAL_MIN=0

# --- Optional: AI explanation layer for recommendations (Gemini / Google AI Studio). ---
# Rules still decide ranking + eligibility; Gemini only phrases "why this fits you".
# No-op without a key. Get one at https://aistudio.google.com/app/apikey
# NOTE on privacy: only anonymized signals are sent (target field, interest tags, and the
# rule-generated reasons) - never name, email, bio or precise location. For real student
# data at scale prefer a paid/Workspace tier where inputs are not used for training.
GEMINI_API_KEY= 
GEMINI_MODEL=gemini-1.5-flash
